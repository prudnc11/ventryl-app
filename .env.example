# ── Supabase ──────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Paystack ──────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Use pk_test_... for sandbox, pk_live_... for production
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# ── Optional: Supabase service role key (server-side only, never expose) ──
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Edge Function Secrets (set via: supabase secrets set KEY=value) ──
# PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
# RESEND_API_KEY=re_your-resend-api-key
# AT_API_KEY=your-africa's-talking-api-key
# AT_USERNAME=sandbox
# FROM_EMAIL=notifications@yourdomain.com
